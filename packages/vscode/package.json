{
  "name": "prodman",
  "displayName": "ProdMan",
  "description": "AI-ready spec linting and agent brief launcher for VS Code",
  "version": "0.3.1",
  "publisher": "prodman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prodman/prodman"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "prodman",
    "spec",
    "ai",
    "agent",
    "product-management"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "workspaceContains:CLAUDE.md",
    "workspaceContains:prodman-context/product.md",
    "workspaceContains:features/**/agent-brief.md",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prodman",
          "title": "ProdMan",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "prodman": [
        {
          "id": "prodmanContextHealth",
          "name": "Context Health"
        },
        {
          "id": "prodmanSignalInbox",
          "name": "Signal Inbox"
        },
        {
          "id": "prodmanPipeline",
          "name": "Feature Pipeline",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "prodman.captureSignal",
        "title": "Capture Signal",
        "category": "ProdMan",
        "icon": "$(lightbulb)"
      },
      {
        "command": "prodman.launchAgent",
        "title": "Launch Agent from Brief",
        "category": "ProdMan"
      },
      {
        "command": "prodman.compileSpec",
        "title": "Compile Spec → spec.json",
        "category": "ProdMan"
      },
      {
        "command": "prodman.previewSpec",
        "title": "Preview Compiled Spec",
        "category": "ProdMan"
      },
      {
        "command": "prodman.initWorkspace",
        "title": "Initialize PRODMAN Workspace",
        "category": "ProdMan"
      },
      {
        "command": "prodman.refreshContextHealth",
        "title": "Refresh",
        "category": "ProdMan",
        "icon": "$(refresh)"
      },
      {
        "command": "prodman.refreshSignalInbox",
        "title": "Refresh",
        "category": "ProdMan",
        "icon": "$(refresh)"
      },
      {
        "command": "prodman.refreshPipeline",
        "title": "Refresh",
        "category": "ProdMan",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "prodman.launchAgent",
          "when": "resourceFilename == 'agent-brief.md'",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "prodman.launchAgent",
          "when": "resourceFilename == 'agent-brief.md'"
        },
        {
          "command": "prodman.compileSpec",
          "when": "resourceFilename == 'agent-brief.md'"
        },
        {
          "command": "prodman.previewSpec",
          "when": "resourceFilename == 'agent-brief.md'"
        },
        {
          "command": "prodman.refreshContextHealth",
          "when": "false"
        },
        {
          "command": "prodman.refreshSignalInbox",
          "when": "false"
        },
        {
          "command": "prodman.refreshPipeline",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "prodman.captureSignal",
          "when": "view == prodmanSignalInbox",
          "group": "navigation"
        },
        {
          "command": "prodman.refreshSignalInbox",
          "when": "view == prodmanSignalInbox",
          "group": "navigation"
        },
        {
          "command": "prodman.refreshContextHealth",
          "when": "view == prodmanContextHealth",
          "group": "navigation"
        },
        {
          "command": "prodman.refreshPipeline",
          "when": "view == prodmanPipeline",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "echo \"No vscode tests yet\" && exit 0",
    "package": "npm run build && vsce package --no-dependencies",
    "publish": "npm run build && vsce publish --no-dependencies"
  },
  "dependencies": {
    "@prodman/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
